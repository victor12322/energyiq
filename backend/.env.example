# ── Database ─────────────────────────────────────────────────────────────────
# Supabase (PostgreSQL) — get from: Supabase → Project Settings → Database
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.ciupvopucizjufotlgqm.supabase.co:5432/postgres

# Local SQLite fallback: change schema.prisma provider to "sqlite"
# DATABASE_URL=file:./dev.db

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── Stripe ───────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Get after creating a webhook endpoint in Stripe dashboard
# Webhook URL: https://your-domain.com/api/billing/webhook  (or Supabase Edge Function URL)
# Events to listen: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=whsec_...

# Create 3 products in Stripe dashboard → each with a monthly recurring price
# Copy the price IDs (price_...) here:
STRIPE_PRICE_STARTER=price_...       # €299/month — Starter
STRIPE_PRICE_GROWTH=price_...        # €599/month — Growth
STRIPE_PRICE_ENTERPRISE=price_...    # €999/month — Enterprise

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get from: Supabase → Project Settings → API
SUPABASE_URL=https://ciupvopucizjufotlgqm.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...  # service_role key — keep secret, never expose to frontend
