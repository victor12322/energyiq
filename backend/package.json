{
  "name": "energyiq-backend",
  "version": "1.0.0",
  "description": "EnergyIQ B2B Energy Efficiency SaaS - Backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev --name init",
    "db:seed": "ts-node --transpile-only prisma/seed.ts",
    "db:reset": "prisma db push --force-reset && ts-node --transpile-only prisma/seed.ts",
    "simulate": "ts-node --transpile-only src/services/meterSimulator.ts",
    "postinstall": "prisma generate",
    "vercel-build": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "pdfkit": "^0.15.0",
    "stripe": "^22.2.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.0",
    "@types/pdfkit": "^0.13.3",
    "prisma": "^5.7.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
