{
  "name": "energyiq",
  "version": "1.0.0",
  "description": "EnergyIQ — B2B Energy Efficiency SaaS (unified frontend + backend)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "ts-node-dev --respawn --transpile-only server/index.ts",
    "build": "prisma generate && vite build",
    "preview": "vite preview",
    "vercel-build": "prisma generate && vite build",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "ts-node --transpile-only prisma/seed.ts",
    "db:reset": "prisma db push --force-reset && ts-node --transpile-only prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.312.0",
    "pdfkit": "^0.15.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.1",
    "recharts": "^2.10.3",
    "stripe": "^22.2.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.0",
    "@types/pdfkit": "^0.13.3",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.10"
  }
}
